# Discord OAuth（https://discord.com/developers/applications）
# 1. New Application
# 2. OAuth2 → Redirects 加入（必須與網頁同源，走 Vite proxy）：
#    http://127.0.0.1:5173/api/auth/discord/callback
# 3. 複製 Client ID / Client Secret

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:5173/api/auth/discord/callback

# 登入成功後導回的網頁
WEB_ORIGIN=http://127.0.0.1:5173

# Bot 玩家資料（預設指到同層 artale-lottery-bot）
# PLAYER_DATA_PATH=/absolute/path/to/player-data.json

# 本機可用 ID 登入（正式環境請設 0）
ALLOW_DEV_LOGIN=1

PORT=8787
