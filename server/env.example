# Discord OAuth（https://discord.com/developers/applications）
# 本機 Redirect（Vite proxy 同源）：
#    http://127.0.0.1:5173/api/auth/discord/callback
# SIT Redirect：
#    https://maplestory-word.duckdns.org/defense/api/auth/discord/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:5173/api/auth/discord/callback

# 登入成功後導回的網頁
WEB_ORIGIN=http://127.0.0.1:5173

# Bot 公式模組目錄（sit-kevin 用 /home/kevin.chu/artale-bot）
# BOT_ROOT=/home/kevin.chu/artale-bot

# Bot 玩家資料（預設指到同層 artale-lottery-bot）
# PLAYER_DATA_PATH=/absolute/path/to/player-data.json

# 正式靜態前端目錄（npm run build 的 dist）
# STATIC_DIR=/home/kevin.chu/artale-web/dist

# HTTPS cookie
# COOKIE_SECURE=1

# 本機可用 ID 登入（正式環境建議 0；SIT 可暫開 1）
ALLOW_DEV_LOGIN=1

PORT=8787
# HOST=127.0.0.1
